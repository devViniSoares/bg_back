# Banco de dados
DB_HOST=127.0.0.1
DB_USERNAME=root
DB_PASSWORD=

# JWT — troque por chaves seguras em produção
JWT_SECRET=bigode-autopecas-chave-secreta-minimo-256bits-troque-em-producao
JWT_REFRESH_EXPIRATION=604800000

# Admin padrão (criado automaticamente na primeira inicialização)
ADMIN_EMAIL=admin@bigodeautopecas.com
ADMIN_SENHA=admin123
ADMIN_NOME=Administrador

# CORS — URLs do frontend permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# E-mail (opcional — remova os comentários para habilitar notificações)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=seu-email@gmail.com
# MAIL_PASSWORD=sua-senha-de-app